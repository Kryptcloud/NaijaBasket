{
  "name": "naijabasket-backend",
  "version": "1.0.0",
  "description": "Secure backend for naijabasket e-commerce platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:ts": "node dist/server.js",
    "build": "tsc",
    "dev": "node server.js",
    "dev:ts": "ts-node-dev --respawn --transpile-only src/server.ts",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "migrate": "node dist/migrations/run.js"
  },
  "keywords": ["ecommerce", "eggs", "api", "payment"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.0",
    "bcrypt": "^5.1.1",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.0",
    "axios": "^1.6.0",
    "crypto": "^1.0.1",
    "uuid": "^9.0.1",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcrypt": "^5.0.2",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/parser": "^6.16.0",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11"
  }
}
