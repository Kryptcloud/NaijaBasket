# naijabasket Backend Environment Variables

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/naijabasket
NODE_ENV=development

# Server
PORT=3000
HOST=localhost
API_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-characters
JWT_EXPIRY=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-this-too
REFRESH_TOKEN_EXPIRY=30d

# Paystack
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key_here
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# Crypto Payments
BLOCKCHAIN_RPC_URL=https://mainnet.infura.io/v3/your-infura-key
MERCHANT_WALLET_ADDRESS=0x4978D9a8dD862B066c61c51228310fa10134979f

# Email (Optional - for order confirmations)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# WebSocket / Real-time (Socket.io)
SOCKET_IO_ENABLED=true
SOCKET_IO_CORS_ORIGIN=http://localhost:5173

# Accounting Dashboard (Optional defaults)
COST_PER_CRATE_MULTIPLIER=0.35
EXPENSE_THRESHOLD_ALERT=0.4
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@naijabasket.com

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,https://naijabasket.com

# Security
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=15m
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Admin
ADMIN_EMAIL=admin@naijabasket.com
ADMIN_PASSWORD=change-this-strong-password
